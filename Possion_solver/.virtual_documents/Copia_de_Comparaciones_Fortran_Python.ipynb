                    ((V[i, j + 1] + V[i, j - 1]) * h**2) -
                    (source[i, j] * h**2 * k**2)
                ) / (2 * (h**2 + k**2))

                S1.append(abs(V_new - V[i, j]))
                V[i, j] = V_new

        delta = max(S1)
